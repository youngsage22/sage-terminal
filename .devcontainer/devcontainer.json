{
  "name": "SAGE Terminal Dev",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-windows-2022",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/powershell:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "twxs.cmake",
        "ms-vscode.powershell",
        "github.vscode-github-actions",
        "editorconfig.editorconfig",
        "ms-vscode.vscode-json",
        "usernamehw.errorlens",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "C_Cpp.default.cppStandard": "c++17",
        "C_Cpp.default.compilerPath": "cl.exe",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.windows": "PowerShell"
      }
    }
  },
  "postCreateCommand": "echo '🎨 SAGE Terminal dev environment ready! Open OpenConsole.sln in Visual Studio to build.' && git submodule update --init --recursive",
  "remoteUser": "vscode",
  "hostRequirements": {
    "os": "windows"
  },
  "forwardPorts": [],
  "mounts": [],
  "secrets": {}
}
